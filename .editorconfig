# ============================================================
# .editorconfig
# エディタ横断でコードスタイルを統一する設定ファイル
# VSCode, JetBrains, Vim 等の主要エディタが対応している
# 詳細: https://editorconfig.org
# ============================================================

# このファイルがルート（最上位）の設定であることを宣言する
root = true

# ============================================================
# 全ファイル共通のデフォルト設定
# ============================================================
[*]
# 文字エンコーディング
charset = utf-8

# 改行コード（LF を基本とする。WSL/Linux/macOS で統一）
end_of_line = lf

# インデントのスタイル（スペース）
indent_style = space

# インデント幅のデフォルト
indent_size = 4

# ファイル末尾に改行を挿入する
insert_final_newline = true

# 行末の余分な空白を削除する
trim_trailing_whitespace = true

# ============================================================
# Web 系（インデント 2 スペースが慣習）
# ============================================================
[*.{js,mjs,cjs,ts,tsx,jsx,vue,svelte}]
indent_size = 2

[*.{html,htm}]
indent_size = 2

[*.{css,scss,sass,less}]
indent_size = 2

[*.{json,jsonc,json5}]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2

# ============================================================
# シェルスクリプト
# ============================================================
[*.{sh,bash,zsh}]
indent_size = 4

# ============================================================
# Python
# ============================================================
[*.py]
indent_size = 4

# ============================================================
# Markdown（末尾スペースは意味を持つ場合があるので除外）
# ============================================================
[*.{md,mdx}]
trim_trailing_whitespace = false
indent_size = 2

# ============================================================
# Makefile（タブが必須）
# ============================================================
[Makefile]
indent_style = tab

# ============================================================
# Go（タブが慣習）
# ============================================================
[*.go]
indent_style = tab
