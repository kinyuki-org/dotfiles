# ============================================================
# ~/.inputrc
# Readline ライブラリの設定（bash のコマンドライン編集に効く）
# ============================================================

# ============================================================
# 補完の挙動
# ============================================================

# 補完時に大文字・小文字を区別しない
set completion-ignore-case on

# ハイフン（-）とアンダースコア（_）を同一視して補完する
set completion-map-case on

# 補完候補が複数あるとき、一覧を即座に表示する（2回押し不要）
set show-all-if-ambiguous on

# 補完候補が一意に絞れない場合も一覧を表示する
set show-all-if-unmodified on

# 補完候補リストで、共通部分を色で強調表示する
set colored-completion-prefix on

# 補完候補をカラーで分類表示する（ls --color と同じ色使い）
set colored-stats on

# 補完候補のシンボリックリンクにスラッシュを付ける
set mark-symlinked-directories on

# ============================================================
# 履歴検索
# ============================================================

# Ctrl+P / Ctrl+N で前後の履歴を検索（入力済みのテキストでフィルタ）
"\C-p": history-search-backward
"\C-n": history-search-forward

# 上下矢印でも同様に履歴を検索する
"\e[A": history-search-backward
"\e[B": history-search-forward

# ============================================================
# カーソル移動
# ============================================================

# Ctrl+← / Ctrl+→ で単語単位に移動する
"\e[1;5C": forward-word
"\e[1;5D": backward-word

# ============================================================
# 表示
# ============================================================

# 補完候補が多いとき「表示しますか？」の確認を出すしきい値（件数）
set completion-query-items 200

# ページャを使わず補完候補を一括表示する
set page-completions off

# ビープ音を鳴らさない
set bell-style none
