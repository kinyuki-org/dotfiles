# ============================================================
# ~/.zshrc_prompt
# プロンプト表示設定（zsh 用）
# ~/.zshrc から source される
#
# 表示イメージ:
#    kinyuki@MacBook    ~/work/dotfiles    main
#   ❯ _
# ============================================================

__set_prompt() {
    local exit_code=$?

    local esc=$'\033'
    __fg() { echo -n "%{${esc}[38;5;${1}m%}"; }
    __bg() { echo -n "%{${esc}[48;5;${1}m%}"; }
    local R="%{${esc}[0m%}"

    local USER_BG=$(__bg 22)   USER_FG=$(__fg 156)
    local PATH_BG=$(__bg 17)   PATH_FG=$(__fg 75)
    local GIT_BG=$(__bg 58)    GIT_FG=$(__fg 215)
    local DIRTY_BG=$(__bg 52)  DIRTY_FG=$(__fg 203)
    local VENV_BG=$(__bg 54)   VENV_FG=$(__fg 183)
    local EXIT_BG=$(__bg 52)   EXIT_FG=$(__fg 203)

    local host_label="${HOST%%.*}"

    # ---- exit code セグメント ----
    local exit_seg=""
    if [ $exit_code -ne 0 ]; then
        exit_seg=" ${EXIT_BG}${EXIT_FG}[✗ ${exit_code}]${R}"
    fi

    # ---- venv セグメント ----
    local venv_seg=""
    if [ -n "$VIRTUAL_ENV" ]; then
        local venv_name
        venv_name=$(basename "$VIRTUAL_ENV" | sed 's/-[A-Za-z0-9]*-py[0-9].*//')
        venv_seg=" ${VENV_BG}${VENV_FG}(${venv_name})${R}"
    fi

    # ---- git セグメント ----
    local git_seg=""
    local branch
    branch=$(git symbolic-ref --short HEAD 2>/dev/null)
    if [ -n "$branch" ]; then
        if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
            git_seg=" ${DIRTY_BG}${DIRTY_FG} (${branch} *) ${R}"
        else
            git_seg=" ${GIT_BG}${GIT_FG} (${branch}) ${R}"
        fi
    fi

    # ---- 1行目: バッジ並び ----
    local line1
    line1="${USER_BG}${USER_FG}[%n@${host_label}]${R}"
    line1+="${PATH_BG}${PATH_FG}[%~]${R}"
    line1+="${venv_seg}"
    line1+="${git_seg}"
    line1+="${exit_seg}"

    # ---- 2行目: 入力プロンプト ----
    local prompt_char
    if [ $exit_code -eq 0 ]; then
        prompt_char="$(__fg 114)❯${R}"
    else
        prompt_char="$(__fg 203)❯${R}"
    fi

    PROMPT="${line1}"$'\n'"${prompt_char} "
}

precmd() { __set_prompt; }
