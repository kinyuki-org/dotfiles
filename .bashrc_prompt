# ============================================================
# ~/.bashrc_prompt
# プロンプト表示の設定ファイル（背景色バッジスタイル）
# ~/.bashrc から source される
#
# 表示イメージ:
#    kinyuki@Ubuntu    ~/work/dotfiles    main
#   ❯ _
# ============================================================

__set_ps1() {
    local exit_code=$?

    local R=$'\001\033[0m\002'
    __fg() { printf '\001\033[38;5;%dm\002' "$1"; }
    __bg() { printf '\001\033[48;5;%dm\002' "$1"; }

    # ---- バッジカラー定義（背景色 + 前景色）----
    # user バッジ: ダークグリーン地に明るいグリーン文字
    local USER_BG=$(__bg 22)   USER_FG=$(__fg 156)
    # path バッジ: ダークネイビー地にスカイブルー文字
    local PATH_BG=$(__bg 17)   PATH_FG=$(__fg 75)
    # git バッジ（clean）: ダークアンバー地にゴールド文字
    local GIT_BG=$(__bg 58)    GIT_FG=$(__fg 215)
    # git バッジ（dirty）: ダークレッド地に薄赤文字
    local DIRTY_BG=$(__bg 52)  DIRTY_FG=$(__fg 203)
    # venv バッジ: ダークパープル地に薄パープル文字
    local VENV_BG=$(__bg 54)   VENV_FG=$(__fg 183)
    # exit code バッジ: ダークレッド地に薄赤文字
    local EXIT_BG=$(__bg 52)   EXIT_FG=$(__fg 203)

    local host_label="${WSL_DISTRO_NAME:-${HOSTNAME%%.*}}"

    # ---- exit code セグメント ----
    local exit_seg=""
    if [ $exit_code -ne 0 ]; then
        exit_seg=" ${EXIT_BG}${EXIT_FG}[✗ ${exit_code}]${R}"
    fi

    # ---- venv セグメント ----
    local venv_seg=""
    if [ -n "$VIRTUAL_ENV" ]; then
        local venv_name
        venv_name=$(basename "$VIRTUAL_ENV" | sed 's/-[A-Za-z0-9]*-py[0-9].*//')
        venv_seg=" ${VENV_BG}${VENV_FG}(${venv_name})${R}"
    fi

    # ---- git セグメント ----
    local git_seg=""
    local branch
    # /mnt/ 配下 (Windows FS) は I/O が遅いためスキップ
    [[ "$PWD" == /mnt/* ]] && branch="" || \
    branch=$(git symbolic-ref --short HEAD 2>/dev/null)
    if [ -n "$branch" ]; then
        if ! git diff --quiet 2>/dev/null || ! git diff --cached --quiet 2>/dev/null; then
            # 未コミット変更あり → ダーティバッジ
            git_seg=" ${DIRTY_BG}${DIRTY_FG} (${branch} *) ${R}"
        else
            git_seg=" ${GIT_BG}${GIT_FG} (${branch}) ${R}"
        fi
    fi

    # ---- 1行目: バッジ並び ----
    local line1
    line1="${USER_BG}${USER_FG}[\u@${host_label}]${R}"
    line1+="${PATH_BG}${PATH_FG}[\w]${R}"
    line1+="${venv_seg}"
    line1+="${git_seg}"
    line1+="${exit_seg}"

    # ---- 2行目: 入力プロンプト ----
    local prompt
    if [ $exit_code -eq 0 ]; then
        prompt="$(__fg 114)❯${R}"
    else
        prompt="$(__fg 203)❯${R}"
    fi

    PS1="${line1}\n${prompt} "
}

PROMPT_COMMAND='__set_ps1'
unset color_prompt force_color_prompt
